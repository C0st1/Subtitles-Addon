{
  "version": 2,
  "builds":[
    {
      "src": "src/index.js",
      "use": "@vercel/node"
    }
  ],
  "routes":[
    {
      "src": "/(.*)",
      "dest": "src/index.js"
    }
  ],
  "env": {
    "NODE_ENV": "production"
  },
  "functions": {
    "src/index.js": {
      "memory": 512,
      "maxDuration": 30
    }
  }
}
