# Optional: Set a custom port for local development
PORT=7000

# Optional: Default API keys if not provided by the user config
# OPENSUBTITLES_API_KEY=
# SUBDL_API_KEY=
# SUBSOURCE_API_KEY=

# Rate limiting (requests per window)
# RATE_LIMIT_MAX=100
# RATE_LIMIT_WINDOW_MS=60000

# HTTP timeout in milliseconds
# HTTP_TIMEOUT=5000
# MAX_SOCKETS=20

# Force protocol for subtitle proxy URLs (http or https)
# FORCE_PROTOCOL=
