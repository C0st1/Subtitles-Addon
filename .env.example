# Server Configuration
PORT=7000
NODE_ENV=production

# Optional: Default API keys (used as fallback when not in URL config)
OPENSUBTITLES_API_KEY=
SUBDL_API_KEY=
SUBSOURCE_API_KEY=

# Rate limiting
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW_MS=60000
PER_USER_RATE_LIMIT=60

# HTTP Client
HTTP_TIMEOUT=5000
MAX_SOCKETS=20

# Force protocol for subtitle proxy URLs
FORCE_PROTOCOL=

# Redis Cache (optional - enables persistent caching across serverless invocations)
REDIS_URL=

# API Key Encryption (optional - encrypts keys in URL config)
ENC_SECRET=

# Machine Translation (optional - used when MT fallback is enabled in config)
# MT_SERVICE_TYPE: "google" (default, free, no key), "libretranslate" (self-hosted), "deepl"
MT_SERVICE_TYPE=google
# MT_SERVICE_URL=          # Only needed for libretranslate or deepl
# MT_SERVICE_KEY=          # Only needed for libretranslate (required) or deepl (required)

# URL Shortening Service (optional)
SHORT_URL_SERVICE=

# Analytics (optional - endpoint to receive analytics events)
ANALYTICS_URL=

# Sentry Error Monitoring (optional)
SENTRY_DSN=
